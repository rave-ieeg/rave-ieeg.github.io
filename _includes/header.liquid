  <style>
    body {
      padding: 0!important;
    }
    iframe {
      max-width: 100%;
    }
    pre {
      margin: 0.5em 0;
      padding: 8.5px;
      border: 1px solid #e7e7e7;
      border-radius: 2px;
    }
    .navbar-fit-content {
      width: fit-content;
    }
    .lil-gui {
      color: var(--text-color) !important;
    }
    .hidden.open {
      display: block!important;
    }

    #htmlwidget_container {
      position: relative;
      background-color: rgb(251, 248, 244);
    }
    #viewer-overlay {
      position: absolute;
      z-index: 1023;
      max-width: 100%;
      padding: 0;
      height: calc( 100vh - 150px );
      pointer-events: none;
    }
    .threejs_brain {
      height: calc( 100vh - 150px );
    }

    #viewer-overlay-logo-container {
      position: absolute;
      z-index: 1022;
      transform: translate(0, 15px);
      bottom: 0;
      width: 100%;
      pointer-events: none !important;
    }
    #viewer-overlay-logo {
      width: 120px;
      left: 10px;
    }

    #viewer-overlay-content-wrapper {
      width: 100%;
      height: 100%;
      position: relative;
      margin: 0;
      height: calc( 100vh - 150px );
      padding: 15px 40px; 
    }
    #viewer-overlay-content {
      margin-top: 50vh;
      transform: translate(0, -100%);
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
      width: 400px;
      padding: 15px;
      background: rgba(251,248,244, 0.8);
      pointer-events: all!important;
    }
    #viewer-overlay .viewer-overlay-title span {
      display: block;
    }
    #viewer-overlay .viewer-feature-item {
      display: none;
    }
    #viewer-overlay .viewer-feature-item.active {
      display: block;
    }

    @media (max-width: 576px) {
      #viewer-overlay,
      #viewer-overlay-content-wrapper {
        width: 100%;
        max-height: 50vh;
        padding: 0;
        min-width: auto;
        pointer-events: all;
      }
      .threejs_brain {
        max-height: 50vh;
      }
      .hidden-on-screen-lt-600 {
        display: none;
      }
      #viewer-overlay-content {
        margin-top: 0;
        transform: translate(0, 0);
      }
    }
    @media (max-height: 750px) {
      #viewer-overlay-content {
        margin-top: 0;
        transform: translate(0, 0);
      }
    }
  </style>

  <div id="htmlwidget_container">
    <div class="container-fluid">
      <div class="row">
        <div class="col-xs-12">
          <div id="viewer-overlay">
            <div id="viewer-overlay-content-wrapper">
              <div id="viewer-overlay-content" class="rounded-lg">
                <div class="row">
                  <div class="col-xs-12 cl-sm-12 col-md-12 text-center">
                    <h3>{{ page.cover.message }}</h3>
                  </div>
                  <div class="col-xs-12 cl-sm-12 col-md-12 text-left">
                    {% if page.cover.features %}
                      {% for feature in page.cover.features %}
                        <p class="viewer-feature-item {{ feature.class }}" >
                          {{ feature.text }}
                        </p>
                      {% endfor %}
                    {% endif %}
                  </div>
                  <div class="col-xs-12 cl-sm-12 col-md-12 text-center">
                    <hr />
                    {% for link in page.cover.links %}
                      {% if link.onclick %}
                        <button class="btn rounded {{ link.type }}" type="button" onclick="{{ link.onclick }}">
                          {{ link.text }}
                        </button>
                      {% else %}
                        <a href="{{ link.url }}" class="btn rounded {{ link.type }}" type="button">
                          {{ link.text }}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div id="viewer-overlay-logo-container">
      <div class="container">
          <div class="row">
            <div class="col-xs-12 cl-sm-12 col-md-12">
              <div id="viewer-overlay-logo">
                {% if page.cover.image %}
                  {% assign profile_cover_image_path = page.cover.image | prepend: 'assets/img/' %}
                  {% assign profile_cover_image_class = 'img-fluid z-depth-1 rounded float-left w-100' %}
                  {% capture sizes %}(min-width: {{site.max_width}}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
              30vw, 95vw"{% endcapture %}
                  {%
                    include figure.liquid loading="eager" 
                    path=profile_cover_image_path 
                    class=profile_cover_image_class 
                    sizes=sizes alt=page.cover.image
                    cache_bust=true
                  %}
                {% endif %}
              </div>
            </div>
          </div>
        </div>
    </div>
    <div class="threejs_brain html-widget html-fill-item" id="htmlwidget-b6baefbe903f3615dc28" style="width:100%; ">
    </div>
  </div>
{% else %}
  <header>
    <!-- Nav Bar -->
    <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
      <div class="container">
        {% if page.permalink != '/' %}
          <a class="navbar-brand title font-weight-lighter" href="{{ site.baseurl }}/">
            {% if site.title == 'blank' %}
              {% if site.first_name %}
                <span class="font-weight-bold">
                  {{- site.first_name -}}
                </span>
              {% endif %}
              {% if site.middle_name %}
                {{- site.middle_name -}}
              {% endif %}
              {% if site.last_name %}
                {{- site.last_name -}}
              {% endif %}
            {% else %}
              {{- site.title -}}
            {% endif %}
          </a>
        {% elsif site.enable_navbar_social %}
          <!-- Social Icons -->
          <div class="navbar-brand social">{% include social.liquid %}</div>
        {% endif %}
        <!-- Navbar Toggle -->
        <button
          class="navbar-toggler collapsed ml-auto"
          type="button"
          data-toggle="collapse"
          data-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="sr-only">Toggle navigation</span>
          <span class="icon-bar top-bar"></span>
          <span class="icon-bar middle-bar"></span>
          <span class="icon-bar bottom-bar"></span>
        </button>

        <div class="collapse navbar-collapse text-right" id="navbarNav">
          <ul class="navbar-nav ml-auto flex-nowrap">
            {% for page in site.pages %}
              {% if page.permalink == '/' %} {% assign about_title = page.title %} {% endif %}
            {% endfor %}

            <!-- About -->
            <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
              <a class="nav-link" href="{{ '/' | relative_url }}">
                {{- about_title }}
                {% if page.permalink == '/' %}
                  <span class="sr-only">(current)</span>
                {% endif %}
              </a>
            </li>

            <!-- Other pages -->
            {% assign sorted_pages = site.pages | sort: 'nav_order' %}
            {% for p in sorted_pages %}
              {% if p.nav and p.autogen == null %}
                {% if p.dropdown %}
                  {% assign has_active_child = false %}
                  {% for child in p.children %}
                    {% if page.title == child.title %}
                      {% assign has_active_child = true %}
                    {% endif %}
                  {% endfor %}
                  <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                    <a
                      class="nav-link dropdown-toggle"
                      href="#"
                      id="navbarDropdown"
                      role="button"
                      data-toggle="dropdown"
                      aria-haspopup="true"
                      aria-expanded="false"
                    >
                      {{- p.title }}
                      {% if page.title == p.title or has_active_child %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                      {% for child in p.children %}
                        {% if child.title == 'divider' %}
                          <div class="dropdown-divider"></div>
                        {% else %}
                          <a class="dropdown-item {% if page.title == child.title %}active{% endif %}" href="{{ child.permalink | relative_url }}">
                            {{- child.title -}}
                          </a>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </li>
                {% else %}
                  <li class="nav-item {% if page.url contains p.permalink %}active{% endif %}">
                    {% if p.permalink contains '/blog/' %}{% assign url = '/blog/' %} {% else %}{% assign url = p.url %}{% endif %}
                    <a class="nav-link" href="{{ url | relative_url }}">
                      {{- p.title }}
                      {% if page.url contains p.url %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                  </li>
                {% endif %}
              {% endif %}
            {% endfor %}
            {% if site.search_enabled %}
              <!-- Search -->
              <li class="nav-item">
                <button id="search-toggle" title="Search" onclick="openSearchModal()">
                  <span class="nav-link">ctrl k <i class="ti ti-search"></i></span>
                </button>
              </li>
            {% endif %}
            {% if site.enable_darkmode %}
              <!-- Toogle theme mode -->
              <li class="toggle-container">
                <button id="light-toggle" title="Change theme">
                  <i class="ti ti-sun-moon" id="light-toggle-system"></i>
                  <i class="ti ti-moon-filled" id="light-toggle-dark"></i>
                  <i class="ti ti-sun-filled" id="light-toggle-light"></i>
                </button>
              </li>
            {% endif %}
          </ul>
        </div>
      </div>
    </nav>
    {% if site.enable_progressbar %}
      <!-- Scrolling Progress Bar -->
      <progress id="progress" value="0">
        <div class="progress-container">
          <span class="progress-bar"></span>
        </div>
      </progress>
    {% endif %}
  </header>
{% endif %}

